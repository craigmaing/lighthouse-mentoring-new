---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { Image, Picture } from 'astro:assets';
import { getCollection } from 'astro:content';

// Import images for optimization
import heroImage from '../images/iod-conference-142.jpg';
import rsphBadge from '../images/RSPH-Fellow-Badge.jpg';
import iodAmbassadorBadge from '../images/IoD-Ambassador-badge-web.png';
import cmiFellowCert from '../images/cmi-fellow-certificate.png';
import iodAspiringAward from '../images/iod-aspiring-award-badge.png';
import iodGlobalAward from '../images/iod-global-award-badge.png';

// Import testimonials data
import testimonialsData from '../../testimonials-data.json';

// Filter for homepage featured testimonials - prioritise C-suite and IoD leadership
const homepageTestimonials = testimonialsData
  .filter(t => t.featured && (t.category.includes('c-suite') || t.category.includes('iod-leadership') || t.category.includes('board-advisory')))
  .slice(0, 4);

// Get featured insights
const allInsights = await getCollection('insights');
const featuredInsights = allInsights
  .filter(insight => insight.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const categoryColors = {
  'board-advisory': 'bg-blue-100 text-blue-800',
  'executive-coaching': 'bg-green-100 text-green-800',
  'wellbeing': 'bg-purple-100 text-purple-800',
  'leadership': 'bg-orange-100 text-orange-800',
  'governance': 'bg-gray-100 text-gray-800',
};
---

<Layout
  keywords="board advisory services UK, non-executive director, strategic consultant, executive coaching, board governance, NED recruitment, organisational wellbeing, FCMI Fellow, IoD Ambassador"
  title="Craig Fearn - Strategic Consultant | Board Advisory | Executive Leadership"
  description="Strategic consultant specialising in board advisory and AI-enhanced decision-making. FCMI Fellow | FRSPH Fellow | IoD Ambassador. Board-level expertise across multiple sectors."
>
  <!-- Hero Section -->
  <section class="hero section-padding bg-primary text-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="space-y-8 md:space-y-10">
          <!-- Main Headline -->
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[1.05] tracking-tight">
            The Strategic Advisor Boards Turn to First
          </h1>

          <!-- Supporting Copy -->
          <p class="text-xl md:text-2xl text-gray-50 leading-relaxed font-light">
            Most consultants have frameworks. Craig has boardroom scars. <a href="/about/" class="text-white hover:text-gray-200 underline font-normal">Fellowship-level expertise</a> combined with extensive <a href="/services/board-advisory/" class="text-white hover:text-gray-200 underline font-normal">director-level experience</a> for advice that actually works in the real world.
          </p>

          <!-- Credentials Bar -->
          <div class="flex flex-wrap gap-4 py-6 border-y border-white/10">
            <a href="https://www.iod.com/locations/south-west/news/iod-south-west-announces-wellbeing-ambassador/" target="_blank" rel="noopener noreferrer" class="badge bg-eggshell/10 text-white border-0 hover:bg-eggshell/20 transition-colors px-4 py-2.5 text-base font-medium">IoD Ambassador</a>
            <span class="badge bg-eggshell/10 text-white border-0 px-4 py-2.5 text-base font-medium">FRSPH Fellow</span>
            <span class="badge bg-eggshell/10 text-white border-0 px-4 py-2.5 text-base font-medium">FCMI Fellow</span>
            <span class="badge bg-eggshell/10 text-white border-0 hidden sm:inline-flex px-4 py-2.5 text-base font-medium">IoD Awards Finalist 2025</span>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-5 items-start">
            <Button href="/contact/" variant="secondary" class="text-lg px-8 py-4 shadow-lg hover:shadow-xl transition-shadow">
              Book a Strategy Call
            </Button>
            <Button href="/services/" variant="ghost" class="text-white hover:text-gray-100 text-lg">
              Explore Services
            </Button>
          </div>

          <!-- Trust Indicators -->
          <div class="flex flex-wrap gap-x-10 gap-y-4 text-base md:text-lg text-gray-100 font-medium">
            <div class="flex items-center gap-3">
              <svg class="w-6 h-6 flex-shrink-0 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Cross-Sector Experience</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-6 h-6 flex-shrink-0 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>NHS to Fortune 500</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-6 h-6 flex-shrink-0 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>24-Hour Response Time</span>
            </div>
          </div>
        </div>
        <!-- Craig's Image -->
        <div class="relative lg:block">
          <Picture
            src={heroImage}
            alt="Craig Fearn at IoD Conference"
            class="w-full max-w-md mx-auto rounded-2xl shadow-2xl"
            widths={[400, 600, 800, 1200, 1600]}
            sizes="(max-width: 640px) 400px, (max-width: 768px) 600px, (max-width: 1024px) 800px, (max-width: 1536px) 1200px, 1600px"
            formats={['avif', 'webp']}
            loading="eager"
            fetchpriority="high"
            quality={85}
          />
        </div>

      </div>
    </div>
  </section>

  <!-- Value Proposition Section -->
  <section class="py-20 md:py-32 bg-eggshell">
    <div class="container">
      <div class="text-center max-w-4xl mx-auto mb-20 md:mb-24 space-y-8">
        <h2 class="text-4xl md:text-5xl lg:text-5xl font-bold text-gray-900 leading-tight">
          Strategic Advisory When Stakes Are High
        </h2>
        <p class="text-xl md:text-2xl text-gray-600 leading-relaxed">
          When you need strategic clarity—not generic advice—you need someone who's navigated the same challenges. Board governance. Executive pressure. Organisational complexity. Cultural transformation.
        </p>
        <p class="text-lg md:text-xl text-gray-700 leading-relaxed">
          <a href="/about/" class="text-accent hover:text-accent-dark font-semibold text-lg md:text-xl">Craig has led through it</a>, not just studied it. Extensive board-level experience across NHS, technology, financial services, and professional services. <a href="https://www.iod.com/locations/south-west/news/iod-south-west-announces-wellbeing-ambassador/" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-dark font-semibold text-lg md:text-xl">IoD Ambassador</a>, <a href="/about#credentials" class="text-accent hover:text-accent-dark font-semibold text-lg md:text-xl">FRSPH Fellow, FCMI Fellow</a>—specialised guidance that draws on both deep experience and evidence-based methodology.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-12">
        <!-- Service 1: Board Advisory -->
        <div class="card p-10 flex flex-col group hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="w-20 h-20 bg-accent/10 rounded-xl flex items-center justify-center mb-8 group-hover:bg-accent/15 transition-colors duration-300">
            <svg class="w-10 h-10 text-accent group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-6">Board Advisory & Governance</h3>
          <p class="text-base md:text-lg text-gray-600 leading-relaxed mb-8 flex-grow">
            Navigate complex board dynamics, governance challenges, and strategic decisions. Get clarity from someone who's <a href="/about/" class="text-accent hover:text-accent-dark font-semibold">chaired the meetings and made the calls</a>. Integrates <a href="/services/organisational-wellbeing/" class="text-accent hover:text-accent-dark">wellbeing governance</a> into board strategy.
          </p>
          <a href="/services/board-advisory/" class="inline-flex items-center gap-2 text-accent text-lg font-bold hover:text-accent-dark hover:gap-3 transition-all duration-200 group/link">
            Learn more
            <svg class="w-5 h-5 group-hover/link:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Service 2: Executive Coaching -->
        <div class="card p-10 flex flex-col group hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="w-20 h-20 bg-accent/10 rounded-xl flex items-center justify-center mb-8 group-hover:bg-accent/15 transition-colors duration-300">
            <svg class="w-10 h-10 text-accent group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-6">Executive Coaching</h3>
          <p class="text-base md:text-lg text-gray-600 leading-relaxed mb-8 flex-grow">
            Develop leadership capability with <a href="/about#coaching-credentials" class="text-accent hover:text-accent-dark">coaching that combines psychological insight</a>, strategic thinking, and real-world <a href="/services/board-advisory/" class="text-accent hover:text-accent-dark">board-level experience</a>. Supports leaders navigating <a href="/services/organisational-wellbeing/" class="text-accent hover:text-accent-dark">organisational wellbeing</a> challenges.
          </p>
          <a href="/services/executive-coaching/" class="inline-flex items-center gap-2 text-accent text-lg font-bold hover:text-accent-dark hover:gap-3 transition-all duration-200 group/link">
            Learn more
            <svg class="w-5 h-5 group-hover/link:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Service 3: Organisational Wellbeing -->
        <div class="card p-10 flex flex-col group hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="w-20 h-20 bg-accent/10 rounded-xl flex items-center justify-center mb-8 group-hover:bg-accent/15 transition-colors duration-300">
            <svg class="w-10 h-10 text-accent group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-6">Organisational Wellbeing</h3>
          <p class="text-base md:text-lg text-gray-600 leading-relaxed mb-8 flex-grow">
            Understand organisational wellbeing with <a href="/about#wellbeing-credentials" class="text-accent hover:text-accent-dark font-semibold">human-AI analysis</a> that surfaces patterns invisible to traditional surveys. Strategic insights that connect <a href="/services/organisational-wellbeing/" class="text-accent hover:text-accent-dark">wellbeing to performance</a>, informed by <a href="/services/board-advisory/" class="text-accent hover:text-accent-dark">board-level governance</a> experience.
          </p>
          <a href="/services/organisational-wellbeing/" class="inline-flex items-center gap-2 text-accent text-lg font-bold hover:text-accent-dark hover:gap-3 transition-all duration-200 group/link">
            Learn more
            <svg class="w-5 h-5 group-hover/link:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="py-20 md:py-32 bg-gray-50">
    <div class="container max-w-5xl">
      <div class="text-center mb-20 md:mb-28">
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-8 leading-tight">
          How We Work Together
        </h2>
        <p class="text-xl md:text-2xl text-gray-600 font-medium">
          A straightforward process designed for busy leaders
        </p>
      </div>

      <div class="relative max-w-4xl mx-auto">
        <!-- Connecting Line (Vertical Timeline) -->
        <div class="hidden md:block absolute left-[52px] top-0 bottom-0 w-0.5 bg-gradient-to-b from-accent/40 via-accent/20 to-accent/10"></div>

        <div class="space-y-12 md:space-y-16">
          <!-- Step 1 -->
          <div class="relative group">
            <div class="flex items-start gap-8 md:gap-12 bg-white rounded-2xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
              <div class="flex-shrink-0 relative">
                <!-- Number with background -->
                <div class="w-24 h-24 md:w-28 md:h-28 rounded-2xl bg-accent/10 flex items-center justify-center group-hover:bg-accent/15 transition-all duration-300 group-hover:scale-105">
                  <span class="text-5xl md:text-6xl font-serif text-accent font-bold leading-none">01</span>
                </div>
                <!-- Icon -->
                <div class="absolute -bottom-2 -right-2 w-10 h-10 bg-white rounded-lg shadow-md flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                </div>
              </div>
              <div class="flex-1 pt-2 md:pt-4">
                <h3 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-5 md:mb-6">Strategy Call</h3>
                <p class="text-base md:text-lg text-gray-700 leading-relaxed">
                  45-minute confidential conversation about your challenge. Explore fit and approach. No obligation, no sales pitch—just strategic dialogue.
                </p>
              </div>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="relative group">
            <div class="flex items-start gap-8 md:gap-12 bg-white rounded-2xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
              <div class="flex-shrink-0 relative">
                <!-- Number with background -->
                <div class="w-24 h-24 md:w-28 md:h-28 rounded-2xl bg-accent/10 flex items-center justify-center group-hover:bg-accent/15 transition-all duration-300 group-hover:scale-105">
                  <span class="text-5xl md:text-6xl font-serif text-accent font-bold leading-none">02</span>
                </div>
                <!-- Icon -->
                <div class="absolute -bottom-2 -right-2 w-10 h-10 bg-white rounded-lg shadow-md flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
              </div>
              <div class="flex-1 pt-2 md:pt-4">
                <h3 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-5 md:mb-6">Custom Proposal</h3>
                <p class="text-base md:text-lg text-gray-700 leading-relaxed">
                  Tailored scope based on your specific needs. Clear deliverables, timeline, and transparent investment. Review and refine until it's right.
                </p>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="relative group">
            <div class="flex items-start gap-8 md:gap-12 bg-white rounded-2xl p-8 md:p-10 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
              <div class="flex-shrink-0 relative">
                <!-- Number with background -->
                <div class="w-24 h-24 md:w-28 md:h-28 rounded-2xl bg-accent/10 flex items-center justify-center group-hover:bg-accent/15 transition-all duration-300 group-hover:scale-105">
                  <span class="text-5xl md:text-6xl font-serif text-accent font-bold leading-none">03</span>
                </div>
                <!-- Icon -->
                <div class="absolute -bottom-2 -right-2 w-10 h-10 bg-white rounded-lg shadow-md flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
              </div>
              <div class="flex-1 pt-2 md:pt-4">
                <h3 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-5 md:mb-6">Deliver Results</h3>
                <p class="text-base md:text-lg text-gray-700 leading-relaxed">
                  Structured engagement with clear milestones. Regular progress reviews. Measurable outcomes that matter to your organisation.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Enhanced CTA -->
      <div class="text-center mt-20 md:mt-24">
        <Button href="/contact/" variant="primary">
          Start with a Strategy Call
        </Button>
      </div>
    </div>
  </section>

  <!-- Modern Tools Section -->
  <section class="py-20 md:py-32 bg-white">
    <div class="container max-w-6xl">
      <div class="text-center mb-16 md:mb-20">
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6 leading-tight">
          Modern Tools, Human Judgment
        </h2>
        <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto">
          Where technology amplifies insight and experience guides decisions
        </p>
      </div>

      <!-- Dual Panel Design -->
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 max-w-5xl mx-auto">

        <!-- AI Technology Panel -->
        <div class="group relative bg-gray-50 rounded-2xl p-8 md:p-10 hover:bg-gray-100 transition-all duration-300 hover:shadow-lg">
          <div class="flex items-start gap-6 mb-6">
            <!-- Icon Container -->
            <div class="flex-shrink-0 w-16 h-16 bg-accent/10 rounded-xl flex items-center justify-center group-hover:bg-accent/15 transition-colors duration-300">
              <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-extrabold text-gray-900 mb-3">AI Analysis</h3>
              <p class="text-gray-700 leading-relaxed">
                Pattern recognition at scale. Spotting trends, correlations, and early warnings across complex data sets.
              </p>
            </div>
          </div>
          <div class="pl-22">
            <p class="text-gray-600 text-sm leading-relaxed">
              Applied across board advisory, coaching, and wellbeing services to surface insights that traditional analysis might miss.
            </p>
          </div>
        </div>

        <!-- Human Judgment Panel -->
        <div class="group relative bg-gray-50 rounded-2xl p-8 md:p-10 hover:bg-gray-100 transition-all duration-300 hover:shadow-lg">
          <div class="flex items-start gap-6 mb-6">
            <!-- Icon Container -->
            <div class="flex-shrink-0 w-16 h-16 bg-accent/10 rounded-xl flex items-center justify-center group-hover:bg-accent/15 transition-colors duration-300">
              <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-extrabold text-gray-900 mb-3">Strategic Judgment</h3>
              <p class="text-gray-700 leading-relaxed">
                Board-level experience and professional insight. Understanding context, nuance, and what really matters.
              </p>
            </div>
          </div>
          <div class="pl-22">
            <p class="text-gray-600 text-sm leading-relaxed">
              Technology helps me see more. The strategic decisions, leadership guidance, and organisational wisdom? Always human.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Credentials Section -->
  <section class="py-20 md:py-32 bg-gray-50">
    <div class="container">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 md:mb-20">
          <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6 leading-tight">
            Experience That Can't Be Googled
          </h2>
          <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Most strategic advisors have qualifications. Some have experience. Very few have both at this level.
          </p>
        </div>

        <!-- Professional Fellowships (Tier 1) -->
        <div class="mb-16 md:mb-20">
          <div class="text-center mb-8 md:mb-10">
            <h3 class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">Professional Fellowships</h3>
            <p class="text-gray-600 max-w-2xl mx-auto">Fellowship-level recognition in public health and chartered management</p>
          </div>
          <div class="grid md:grid-cols-2 gap-8 md:gap-10 max-w-4xl mx-auto">
            <!-- FRSPH Fellow -->
            <div class="group relative bg-white rounded-2xl p-8 md:p-10 hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-accent/20">
              <div class="flex flex-col items-center text-center">
                <div class="mb-6 transform group-hover:scale-105 transition-transform duration-300">
                  <Image
                    src={rsphBadge}
                    alt="FRSPH Fellow Badge"
                    class="w-28 h-28 md:w-32 md:h-32 object-contain"
                    widths={[128, 256]}
                    sizes="128px"
                    loading="lazy"
                    format="webp"
                    quality={90}
                  />
                </div>
                <h4 class="text-2xl font-extrabold text-gray-900 mb-3">FRSPH Fellow</h4>
                <p class="text-gray-600 mb-2">Fellow of the</p>
                <a href="https://www.rsph.org.uk/" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent/80 font-medium transition-colors">Royal Society for Public Health</a>
              </div>
            </div>

            <!-- FCMI Fellow -->
            <div class="group relative bg-white rounded-2xl p-8 md:p-10 hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-accent/20">
              <div class="flex flex-col items-center text-center">
                <div class="mb-6 transform group-hover:scale-105 transition-transform duration-300">
                  <Image
                    src={cmiFellowCert}
                    alt="FCMI Fellow Certificate"
                    class="w-28 h-28 md:w-32 md:h-32 object-contain"
                    widths={[128, 256]}
                    sizes="128px"
                    loading="lazy"
                    format="webp"
                    quality={90}
                  />
                </div>
                <h4 class="text-2xl font-extrabold text-gray-900 mb-3">FCMI Fellow</h4>
                <p class="text-gray-600 mb-2">Fellow of the</p>
                <a href="https://www.managers.org.uk/" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent/80 font-medium transition-colors">Chartered Management Institute</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Leadership Recognition (Tier 2) -->
        <div class="mb-16 md:mb-20">
          <div class="text-center mb-8 md:mb-10">
            <h3 class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">Leadership Recognition</h3>
            <p class="text-gray-600 max-w-2xl mx-auto">Appointed ambassador for wellbeing leadership and governance</p>
          </div>
          <div class="max-w-md mx-auto">
            <div class="group relative bg-white rounded-2xl p-8 md:p-10 hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-accent/20">
              <div class="flex flex-col items-center text-center">
                <div class="mb-6 transform group-hover:scale-105 transition-transform duration-300">
                  <Image
                    src={iodAmbassadorBadge}
                    alt="IoD Ambassador Badge"
                    class="w-28 h-28 md:w-32 md:h-32 object-contain"
                    widths={[128, 256]}
                    sizes="128px"
                    loading="lazy"
                    format="webp"
                    quality={90}
                  />
                </div>
                <h4 class="text-2xl font-extrabold text-gray-900 mb-3">
                  <a href="https://www.iod.com/resources/inclusion-and-diversity/craig-fearn-wellbeing-expert/" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">IoD Ambassador</a>
                </h4>
                <p class="text-gray-600 mb-2">Wellbeing Ambassador for</p>
                <a href="https://www.iod.com/" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent/80 font-medium transition-colors">Institute of Directors South West</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Industry Recognition (Tier 3) -->
        <div>
          <div class="text-center mb-8 md:mb-10">
            <h3 class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">Industry Recognition</h3>
            <p class="text-gray-600 max-w-2xl mx-auto">2025 finalist recognitions from the Institute of Directors</p>
          </div>
          <div class="grid md:grid-cols-2 gap-8 md:gap-10 max-w-4xl mx-auto">
            <!-- IoD Aspiring Director Award -->
            <div class="group relative bg-white rounded-2xl p-6 md:p-8 hover:shadow-lg transition-all duration-300 border border-gray-100 hover:border-accent/20">
              <div class="flex flex-col items-center text-center">
                <div class="mb-5 transform group-hover:scale-105 transition-transform duration-300">
                  <Image
                    src={iodAspiringAward}
                    alt="IoD Aspiring Director Award"
                    class="w-full max-w-[240px] h-auto"
                    widths={[240, 480]}
                    sizes="240px"
                    loading="lazy"
                    format="webp"
                    quality={90}
                  />
                </div>
                <h4 class="text-xl font-bold text-gray-900 mb-2">IoD Awards Finalist</h4>
                <p class="text-gray-600 font-medium">Aspiring Director 2025</p>
              </div>
            </div>

            <!-- IoD Global Award -->
            <div class="group relative bg-white rounded-2xl p-6 md:p-8 hover:shadow-lg transition-all duration-300 border border-gray-100 hover:border-accent/20">
              <div class="flex flex-col items-center text-center">
                <div class="mb-5 transform group-hover:scale-105 transition-transform duration-300">
                  <Image
                    src={iodGlobalAward}
                    alt="IoD Global Award"
                    class="w-full max-w-[240px] h-auto"
                    widths={[240, 480]}
                    sizes="240px"
                    loading="lazy"
                    format="webp"
                    quality={90}
                  />
                </div>
                <h4 class="text-xl font-bold text-gray-900 mb-2">IoD Global Award</h4>
                <p class="text-gray-600 font-medium">Finalist 2025</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Insights Section -->
  {featuredInsights.length > 0 && (
    <section class="py-20 md:py-32 bg-white">
      <div class="container max-w-6xl">
        <div class="text-center mb-16 md:mb-20">
          <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6 leading-tight">
            Latest Insights
          </h2>
          <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Expert perspectives on board governance, executive coaching, and organisational wellbeing
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 md:gap-10">
          {featuredInsights.map((insight) => (
            <article class="group relative bg-white rounded-2xl p-8 md:p-10 hover:shadow-2xl transition-all duration-300 border border-gray-100 hover:border-accent/20 hover:-translate-y-1">
              <a href={`/insights/${insight.slug}`} class="absolute inset-0 z-10" aria-label={`Read article: ${insight.data.title}`}></a>

              <div class="flex items-center gap-2 mb-6">
                <span class={`inline-block px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider ${categoryColors[insight.data.category]}`}>
                  {insight.data.category.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
                </span>
              </div>

              <h3 class="text-xl md:text-2xl font-extrabold text-gray-900 mb-4 leading-tight group-hover:text-accent transition-colors">
                {insight.data.title}
              </h3>

              <p class="text-base text-gray-600 mb-6 leading-relaxed line-clamp-3">
                {insight.data.description}
              </p>

              <div class="flex items-center justify-between text-sm pt-6 border-t border-gray-200">
                <time datetime={insight.data.pubDate.toISOString()} class="text-gray-500 font-medium">
                  {insight.data.pubDate.toLocaleDateString('en-GB', {
                    day: 'numeric',
                    month: 'short',
                    year: 'numeric'
                  })}
                </time>
                <span class="text-accent font-bold group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                  Read article
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </article>
          ))}
        </div>

        <div class="text-center mt-16 md:mt-20">
          <Button href="/insights/" variant="secondary">
            View All Insights
          </Button>
        </div>
      </div>
    </section>
  )}

  <!-- Testimonials Section -->
  <section class="py-20 md:py-32 bg-eggshell">
    <div class="container">
      <div class="text-center mb-20 md:mb-24">
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6 leading-tight">
          What Directors Say
        </h2>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed">
          Trusted by board-level leaders across sectors
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 md:gap-14 max-w-5xl mx-auto">
        {homepageTestimonials.map((testimonial) => (
          <div class="relative bg-white rounded-2xl p-10 md:p-12 flex flex-col border border-gray-100 hover:shadow-2xl hover:border-accent/20 hover:-translate-y-1 transition-all duration-300">
            <!-- Large decorative quotation mark -->
            <svg class="absolute top-8 left-8 w-12 h-12 text-accent/10" fill="currentColor" viewBox="0 0 32 32">
              <path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14h-6c0-2.2 1.8-4 4-4V8zm16 0c-3.3 0-6 2.7-6 6v10h10V14h-6c0-2.2 1.8-4 4-4V8z"/>
            </svg>

            <p class="text-xl italic text-gray-800 leading-relaxed mb-10 flex-grow relative pl-4">
              "{testimonial.excerpt}"
            </p>

            <div class="border-t border-gray-200 pt-6">
              <p class="text-lg font-bold text-gray-900 mb-1">{testimonial.name}</p>
              <p class="text-sm text-gray-600 leading-relaxed">
                {testimonial.role}{testimonial.company ? `, ${testimonial.company}` : ''}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 md:py-40 bg-primary text-white relative overflow-hidden">
    <!-- Subtle background decoration -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-0 right-0 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>

    <div class="container relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-5xl md:text-6xl font-extrabold mb-10 leading-tight">
          Start with a Conversation
        </h2>
        <p class="text-xl md:text-2xl text-gray-100 mb-16 leading-relaxed max-w-3xl mx-auto">
          No pressure. No sales pitch. Just a strategic conversation about your challenge. Most clients start with a 45-minute exploratory call to discuss what they're navigating and whether Craig's experience and approach are the right fit.
        </p>

        <!-- Enhanced CTA Button with white space -->
        <div class="inline-block px-8 py-8 rounded-3xl bg-white/5 backdrop-blur-sm border border-white/10">
          <a
            href="/contact/"
            class="inline-flex items-center justify-center gap-3 bg-white text-primary font-bold text-lg px-10 py-5 rounded-xl hover:bg-accent hover:text-white hover:scale-105 transition-all duration-300 shadow-xl hover:shadow-2xl"
          >
            Book My Strategy Call
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <p class="text-base text-gray-300 mt-10 font-medium">
          🔒 All conversations are confidential and obligation-free
        </p>
      </div>
    </div>
  </section>
</Layout>

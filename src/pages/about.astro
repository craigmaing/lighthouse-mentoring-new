---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { Image, Picture } from 'astro:assets';

// Import images for optimization
import craigHeadshot from '../images/craig-headshot.jpg';
import rsphBadge from '../images/RSPH-Fellow-Badge.jpg';
import iodAmbassadorBadge from '../images/IoD-Ambassador-badge-web.png';
import cmiFellowCert from '../images/cmi-fellow-certificate.png';
import iodAspiringAward from '../images/iod-aspiring-award-badge.png';
import iodGlobalAward from '../images/iod-global-award-badge.png';
---

<Layout
  schemaType="person"
  keywords="Craig Fearn, FCMI Fellow, FRSPH Fellow, IoD Ambassador, board governance expert, strategic consultant, non-executive director"
  title="About Craig Fearn | Strategic Consultant & Board Advisor"
  description="Meet Craig Fearn: FCMI Fellow, FRSPH Fellow, and IoD Ambassador. 17 years of board-level experience helping organizations achieve sustainable performance."
>
  <!-- Page Hero -->
  <section class="hero section-padding bg-primary text-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <h1 class="mb-6">
            Strategic Insight From 17 Years at Board Level
          </h1>
          <p class="text-gray-100 leading-relaxed mb-6">
            Bringing pattern recognition and strategic clarity to complex organizational challenges.
          </p>

          <!-- Credentials Bar -->
          <div class="flex flex-wrap gap-3 mb-8">
            <span class="badge bg-white/10 text-white border-0">IoD Ambassador</span>
            <span class="badge bg-white/10 text-white border-0">FRSPH Fellow</span>
            <span class="badge bg-white/10 text-white border-0">FCMI Fellow</span>
            <span class="badge bg-white/10 text-white border-0">IoD Awards Finalist 2025</span>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4">
            <Button href="/contact" variant="secondary">
              Book a Strategy Call
            </Button>
            <Button href="/services" variant="ghost" class="text-white hover:text-gray-100">
              View Services
            </Button>
          </div>
        </div>
        <div>
          <Picture
            src={craigHeadshot}
            alt="Craig Fearn"
            class="w-full max-w-md mx-auto rounded-2xl shadow-2xl"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 800px"
            formats={['avif', 'webp']}
            loading="eager"
            fetchpriority="high"
            quality={85}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Experience Section -->
  <section class="section-padding bg-white">
    <div class="container max-w-4xl">
      <h2 class="text-h2 text-gray-900 mb-8 text-center">Experience That Can't Be Googled</h2>
      <p class="text-gray-600 text-center mb-12">Most strategic advisors have qualifications. Some have experience. Very few have both at this level.</p>

      <div class="space-y-6 text-gray-700 leading-relaxed">
        <p>
          17 years at board level across sectors including healthcare, technology, and professional services. Not as an observer—as the person making the calls. The person navigating stakeholder conflict. The person accountable when strategy meets reality.
        </p>

        <p>
          You don't learn board dynamics from a textbook. You learn them from doing the work, making the mistakes, and earning the wisdom that comes from responsibility.
        </p>

        <p>
          Craig holds three globally-recognized Fellowships—a combination that doesn't exist elsewhere: IoD Ambassador (recognized authority on board governance), FRSPH Fellow (leadership in public health and wellbeing strategy), and FCMI Fellow (mastery of management practice and organizational leadership).
        </p>

        <p>
          This isn't credential-collecting. It's proof of depth in three areas that matter for strategic advisory: governance expertise, wellbeing insight, and management mastery.
        </p>
      </div>
    </div>
  </section>

  <!-- Credentials Section -->
  <section class="section-padding bg-gray-50">
    <div class="container max-w-5xl">
      <div class="text-center mb-12">
        <h2 class="text-h2 text-gray-900 mb-4">Professional Credentials</h2>
        <p class="text-xl text-gray-600">
          Fellowship-level expertise across governance, public health, and management practice.
        </p>
      </div>

      <!-- First Row: 3 Main Credentials -->
      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div class="credential-badge">
          <Image
            src={rsphBadge}
            alt="FRSPH Fellow Badge"
            class="credential-badge__image"
            widths={[120, 240]}
            sizes="120px"
            loading="lazy"
            format="webp"
            quality={90}
          />
          <h3 class="credential-badge__title">FRSPH Fellow</h3>
          <p class="credential-badge__subtitle">Royal Society for Public Health</p>
        </div>

        <div class="credential-badge">
          <Image
            src={iodAmbassadorBadge}
            alt="IoD Ambassador Badge"
            class="credential-badge__image"
            widths={[120, 240]}
            sizes="120px"
            loading="lazy"
            format="webp"
            quality={90}
          />
          <h3 class="credential-badge__title">IoD Ambassador</h3>
          <p class="credential-badge__subtitle">Institute of Directors South West</p>
        </div>

        <div class="credential-badge">
          <Image
            src={cmiFellowCert}
            alt="FCMI Fellow Certificate"
            class="credential-badge__image"
            widths={[120, 240]}
            sizes="120px"
            loading="lazy"
            format="webp"
            quality={90}
          />
          <h3 class="credential-badge__title">FCMI Fellow</h3>
          <p class="credential-badge__subtitle">Chartered Management Institute</p>
        </div>
      </div>

      <!-- Second Row: Awards -->
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-12">
        <div class="credential-badge">
          <Image
            src={iodAspiringAward}
            alt="IoD Aspiring Director Award"
            class="credential-badge__image credential-badge__image--award"
            widths={[300, 600]}
            sizes="300px"
            loading="lazy"
            format="webp"
            quality={90}
          />
          <h3 class="credential-badge__title">IoD Awards Finalist</h3>
          <p class="credential-badge__subtitle">Aspiring Director 2025</p>
        </div>

        <div class="credential-badge">
          <Image
            src={iodGlobalAward}
            alt="IoD Global Award"
            class="credential-badge__image credential-badge__image--award"
            widths={[300, 600]}
            sizes="300px"
            loading="lazy"
            format="webp"
            quality={90}
          />
          <h3 class="credential-badge__title">IoD Global Award</h3>
          <p class="credential-badge__subtitle">Finalist 2025</p>
        </div>
      </div>

      <!-- Additional Qualifications -->
      <div class="text-center">
        <p class="text-gray-700 font-semibold mb-2">
          Additional Qualifications
        </p>
        <p class="text-gray-600">
          MEd, BSc (Hons), PGCE, QTLS | EMCC Professional Coach
        </p>
      </div>
    </div>
  </section>

  <!-- Sectors Section -->
  <section class="section-padding bg-white">
    <div class="container max-w-4xl">
      <h2 class="text-h2 text-gray-900 mb-8 text-center">Sectors & Impact</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="card p-8">
          <h3 class="text-h3 text-gray-900 mb-4">100+ Organizations Supported</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>NHS Trusts and Healthcare</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Technology and Software</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Financial Services</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Manufacturing</span>
            </li>
          </ul>
        </div>

        <div class="card p-8">
          <h3 class="text-h3 text-gray-900 mb-4">How Directors Work With Craig</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Board advisory and NED services</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Strategic transformation programs</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Executive coaching for resilience</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span>Wellbeing governance frameworks</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-gradient-to-r from-primary to-primary-dark text-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-h2 font-bold mb-6">
          Start with a Conversation
        </h2>
        <p class="text-gray-100 mb-8 leading-relaxed">
          No pressure. No sales pitch. Just a strategic conversation about your challenge. Most clients start with a 45-minute exploratory call to discuss what they're navigating and whether Craig's experience and approach are the right fit.
        </p>
        <Button href="/contact" variant="secondary">
          Book a Strategy Call
        </Button>
        <p class="text-sm text-gray-100 mt-4">
          All conversations are confidential and obligation-free.
        </p>
      </div>
    </div>
  </section>
</Layout>
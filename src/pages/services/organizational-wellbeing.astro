---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { Picture } from 'astro:assets';
import iodConference07 from '../../images/iod-conference-07.jpg';
---

<Layout
  title="Organizational Wellbeing Audit Services | Lighthouse Mentoring"
  description="Organizational wellbeing audits with human-AI analysis. FRSPH Fellow providing strategic insights beyond traditional surveys. Board-level wellbeing governance."
  keywords="organizational wellbeing audit, workplace wellbeing consultant, employee wellbeing assessment, wellbeing audit services, wellbeing strategy consultant"
>
  <!-- Hero Section -->
  <section class="hero section-padding bg-primary text-white">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <div class="inline-block bg-accent/20 text-white px-4 py-2 rounded-full text-sm font-semibold mb-6">
            FRSPH Fellow | AI-Enhanced Analysis
          </div>
          <h1 class="mb-6">
            Understand Wellbeing Beyond the Survey
          </h1>
          <p class="text-gray-100 leading-relaxed mb-8">
            Human-AI analysis that surfaces patterns traditional surveys miss. Strategic insights that connect organizational wellbeing to performance, governance, and culture.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button href="/contact" variant="secondary">
              Discuss a Wellbeing Audit
            </Button>
            <Button href="#what-included" variant="ghost" class="text-white hover:text-gray-100">
              Learn More
            </Button>
          </div>
        </div>
        <div class="hidden lg:block">
          <Picture
            src={iodConference07}
            alt="Craig Fearn - Wellbeing Consultant"
            class="w-full max-w-md mx-auto rounded-2xl shadow-2xl"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 800px"
            formats={['avif', 'webp']}
            loading="eager"
            fetchpriority="high"
            quality={85}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section id="what-included" class="section-padding bg-white">

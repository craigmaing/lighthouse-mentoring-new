---
import { getCollection } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const insights = await getCollection('insights');
  return insights.map((insight) => ({
    params: { slug: insight.slug },
    props: { insight },
  }));
}

const { insight } = Astro.props;
const { Content } = await insight.render();

---

<BlogPostLayout
  title={insight.data.title}
  description={insight.data.description}
  pubDate={insight.data.pubDate}
  author={insight.data.author}
  authorCredentials={insight.data.authorCredentials}
  readTime={insight.data.readTime}
  tldr={insight.data.tldr}
  keyTakeaways={insight.data.keyTakeaways}
  faqs={insight.data.faqs}
  image={insight.data.image}
  imageAlt={insight.data.imageAlt}
  tags={insight.data.tags}
  category={insight.data.category}
>
  <Content />
</BlogPostLayout>

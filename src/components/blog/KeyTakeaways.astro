---
interface Props {
  takeaways: string[];
}

const { takeaways } = Astro.props;
---

<div class="key-takeaways bg-gradient-to-br from-primary/5 to-accent/5 border-2 border-accent/20 rounded-lg p-8 my-12">
  <h2 class="text-2xl font-bold text-primary mb-6 flex items-center gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
      <path d="M20 6 9 17l-5-5"></path>
    </svg>
    Key Takeaways
  </h2>

  <ul class="space-y-4">
    {takeaways.map((takeaway) => (
      <li class="flex items-start gap-4 bg-white p-4 rounded-md border border-gray-100">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent flex-shrink-0 mt-1">
          <path d="m9 18 6-6-6-6"></path>
        </svg>
        <span class="text-primary font-medium leading-relaxed">{takeaway}</span>
      </li>
    ))}
  </ul>
</div>
